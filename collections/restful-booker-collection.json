        {
          "name": "Create Booking - Data Driven",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"No string fields should be empty (defect scan)\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const booking = jsonData.booking || jsonData; // handles both nested and flat responses\r",
                  "\r",
                  "    const emptyFields = [];\r",
                  "\r",
                  "    Object.keys(booking).forEach(function (key) {\r",
                  "        const value = booking[key];\r",
                  "        if (typeof value === 'string' && value.trim() === '') {\r",
                  "            emptyFields.push(key);\r",
                  "        }\r",
                  "    });\r",
                  "\r",
                  "    if (emptyFields.length > 0) {\r",
                  "        pm.expect.fail(\"Empty string field(s) accepted without validation: \" + emptyFields.join(', '));\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Calculate a checkin date 14 days from today\r",
                  "const today = new Date();\r",
                  "const checkinDate = new Date(today);\r",
                  "checkinDate.setDate(today.getDate() + 14);\r",
                  "\r",
                  "const checkoutDate = new Date(checkinDate);\r",
                  "checkoutDate.setDate(checkinDate.getDate() + 7);\r",
                  "\r",
                  "// Format as YYYY-MM-DD\r",
                  "const formatDate = (date) => date.toISOString().split('T')[0];\r",
                  "\r",
                  "pm.variables.set(\"dynamic_checkin\", formatDate(checkinDate));\r",
                  "pm.variables.set(\"dynamic_checkout\", formatDate(checkoutDate));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"{{firstname}}\",\r\n    \"lastname\": \"{{lastname}}\",\r\n    \"totalprice\": {{totalprice}},\r\n    \"depositpaid\": {{depositpaid}},\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-08-01\",\r\n        \"checkout\": \"2026-08-10\"\r\n    },\r\n    \"additionalneeds\": \"{{additionalneeds}}\"\r\n}",
