                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has bookingid\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property('bookingid');\r",
                  "    pm.expect(jsonData.bookingid).to.be.a('number');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking details match what was sent\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.booking.firstname).to.eql(\"Jane\");\r",
                  "    pm.expect(jsonData.booking.lastname).to.eql(\"Doe\");\r",
                  "    pm.expect(jsonData.booking.totalprice).to.eql(150);\r",
                  "    pm.expect(jsonData.booking.bookingdates.checkin).to.eql(\"2026-07-01\");\r",
                  "});\r",
                  "\r",
                  "// Capture bookingid for reuse in later requests (Update/Delete)\r",
                  "const jsonData = pm.response.json();\r",
                  "pm.environment.set(\"booking_id\", jsonData.bookingid);"
                ],
